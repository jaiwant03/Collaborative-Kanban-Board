# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/kanban_board?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── API URL ───────────────────────────────────────────────────────────────────
API_URL=https://kanban-board-backend.onrender.com

# ── Frontend URL (used inside invitation email links) ─────────────────────────
# !! IMPORTANT — this value must match what you register in Supabase !!
#
# Set this to your Vercel deployment URL on Render.
# Locally it stays as http://localhost:3000.
#
# After updating this, also do the following in the Supabase dashboard:
#   Authentication → URL Configuration
#     Site URL:      https://your-app.vercel.app
#     Redirect URLs: https://your-app.vercel.app/**   ← click "Add URL"
#
# Without adding the Vercel URL to the Supabase redirect allowlist, Supabase
# will silently ignore the redirectTo we pass and fall back to Site URL
# (localhost), so invitation links will point to localhost even in production.
FRONTEND_URL=https://your-app.vercel.app

# ── Email — Supabase Auth (inviteUserByEmail) ─────────────────────────────────
# Supabase uses your configured "Invite User" email template to send invites.
#
# Steps:
#   1. Open Supabase → Project Settings → API
#   2. Copy the Project URL → SUPABASE_URL
#   3. Copy the service_role secret key → SUPABASE_SERVICE_KEY
#      (NOT the anon key — admin privileges are required to call inviteUserByEmail)
#   4. Configure your invite template:
#      Supabase → Authentication → Email Templates → Invite User
#      Set the "Confirm signup" URL to: {{ .SiteURL }}/invite/accept?token={{ .Token }}
#
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# ── File Uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760

# Storage backend: local | supabase | cloudinary
# Set to 'supabase' to upload files to Supabase Storage instead of local disk.
UPLOAD_STORAGE=supabase

# Supabase Storage bucket name (create this bucket in Supabase → Storage)
# Make sure the bucket is set to PUBLIC in Supabase so the public URL works.
SUPABASE_BUCKET=attachments
